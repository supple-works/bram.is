---
import type { HTMLAttributes } from "astro/types";
import { MetaData, type MetaDataProps } from "@components/elements";

import "virtual:sugarcube.css";
import "../styles/global.css";
import { useSettings, type PageProps } from "src/utilities/api/queries";
import { getLocaleFromURL } from "src/utilities/locale";
import { Logo } from "@components/molecules/Logo";

const locale = getLocaleFromURL(Astro.url.pathname);

export interface Props extends HTMLAttributes<"html">, MetaDataProps {
	type?: string;
	alternativeTranslations?: PageProps["alternativeTranslations"];
	withOutMasthead?: boolean;
}

const settings = await useSettings({ locale });

const { type, alternativeTranslations, metaData, skipMetaTitleSuffix, withOutMasthead } = Astro.props;
---

<!doctype html>
<html lang={locale.id} data-page-type={type}>
	<head>
		<MetaData
			metaData={metaData}
			skipMetaTitleSuffix={skipMetaTitleSuffix}
			alternativeTranslations={alternativeTranslations}
		/>
		<link rel="preload" href="/fonts/alcyone/Alcyone-SemiBold.woff2" as="font" type="font/woff2" crossorigin>
		<link rel="preload" href="/fonts/alcyone/Alcyone-Regular.woff2" as="font" type="font/woff2" crossorigin>
	</head>
	<body>
		{withOutMasthead ? null : (<header class="masthead">
			<div class="masthead__inner | retain"><Logo /></div>
		</header>)}
		<main id="content">
			<slot />
		</main>
		<!-- <footer>Footer</footer> -->
	</body>
</html>

<style>
	@layer block {
		.masthead {
			padding-block: var(--core-space-m);

		}

		.masthead__inner {
			display: flex;
		}
	}
</style>
