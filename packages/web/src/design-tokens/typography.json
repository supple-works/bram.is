						}
					}
				},
				"2": {
					"$value": { "value": 1.5625, "unit": "rem" },
					"$extensions": {
						"sh.sugarcube": {
							"fluid": {
								"min": { "value": 1.5625, "unit": "rem" },
								"max": { "value": 1.9531, "unit": "rem" }
							}
						}
					}
				},
				"3": {
					"$value": { "value": 1.9531, "unit": "rem" },
					"$extensions": {
						"sh.sugarcube": {
							"fluid": {
								"min": { "value": 1.9531, "unit": "rem" },
