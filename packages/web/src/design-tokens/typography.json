							}
						}
					}
				}
			}
		}
	},
	"font": {
		"family": {
			"$type": "fontFamily",
			"sans": {
				"$value": [
					"Alcyone",
					"system-ui"
				]
			}
		},
		"weight": {
			"$type": "fontWeight",
			"thin": { "$value": 100 },
			"extralight": { "$value": 200 },
			"light": { "$value": 300 },
			"normal": { "$value": 400 },
			"medium": { "$value": 500 },
			"semibold": { "$value": 600 },
			"bold": { "$value": 700 },
			"black": { "$value": 900 }
		}
	},
	"leading": {
		"$type": "number",
		"none": { "$value": 1 },
		"tight": { "$value": 1.25 },
		"normal": { "$value": 1.5 },
		"relaxed": { "$value": 1.75 }
	},
	"tracking": {
		"$type": "dimension",
		"tight": { "$value": { "value": -0.025, "unit": "rem" } },
		"normal": { "$value": { "value": 0, "unit": "rem" } },
		"wide": { "$value": { "value": 0.025, "unit": "rem" } }
	},
	"text": {
		"base": { "$value": "{core.text.step.0}" },
		"tiny": { "$value": "{core.text.step.-2}" },
		"small": { "$value": "{core.text.step.-1}" },
		"huge": { "$value": "{core.text.step.6}" },
		"heading-1": { "$value": "{core.text.step.3}" },
		"heading-2": { "$value": "{core.text.step.2}" },
		"heading-3": { "$value": "{core.text.step.1}" },
		"heading-4": { "$value": "{core.text.step.0}" },
		"heading-5": { "$value": "{core.text.step.0}" },
		"heading-6": { "$value": "{core.text.step.0}" }
	},
	"heading": {
		"family": {
			"$type": "fontFamily",
			"$value": "{font.family.sans}"
		},
		"weight": {
			"$type": "fontWeight",
			"$value": "{font.weight.semibold}"
		},
		"leading": {
			"$type": "number",
			"$value": "{leading.none}"
		},
		"tracking": {
			"$type": "dimension",
			"$value": "{tracking.normal}"
		},
		"size": {
			"$type": "dimension",
			"$value": "{text.base}"
		}
	},
	"body": {
		"family": {
			"$type": "fontFamily",
			"$value": "{font.family.sans}"
		},
		"weight": {
			"$type": "fontWeight",
			"$value": "{font.weight.normal}"
		},
		"leading": {
			"$type": "number",
			"$value": "{leading.normal}"
		},
		"tracking": {
			"$type": "dimension",
			"$value": "{tracking.normal}"
		},
		"size": {
			"$type": "dimension",
			"$value": "{text.base}"
		}
	}
}
