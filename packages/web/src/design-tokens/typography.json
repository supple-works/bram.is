					"$value": { "value": 3.0518, "unit": "rem" },
					"$extensions": {
						"sh.sugarcube": {
							"fluid": {
								"min": { "value": 3.0518, "unit": "rem" },
								"max": { "value": 3.8147, "unit": "rem" }
							}
						}
