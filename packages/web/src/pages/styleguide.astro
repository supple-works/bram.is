---
import Layout from "@layouts/Layout.astro";
import { Swatch } from "@components/styleguide";

import StyleDictionary from "style-dictionary";
import { convertTokenData } from "style-dictionary/utils";

const sd = new StyleDictionary({
	source: ["src/design-tokens/**/*.json"],
});
await sd.hasInitialized;
const flatTokens = convertTokenData(sd.tokens, {
	output: "array",
	usesDtcg: true,
});

const colorTokens = flatTokens.filter((token) => token["$type"] === "color" && token.filePath.endsWith("/colors.json"));

console.log("colorTokens", colorTokens);
---

<Layout
	metaData={{
		title: "Styleguide",
		description: "bram.is styleguide, depicting the design language used on the website.",
	}}
>
	<div>
		<div>
			<h1>Styleguide</h1>

			<ul>
				<li><a href="#colors">Colors</a></li>
				<li><a href="#typography">Typography</a></li>
			</ul>

			<div>
				<section id="colors">
					<h2>Colors</h2>

					<ul role="list" class="grid-auto">
						{
							colorTokens
								.filter((token) => token.key)
								.map((token) => (
									<li>
										<Swatch color={token.key.replace("{", "").replace("}", "").replaceAll(".", "-")} />
									</li>
								))
						}
					</ul>
				</section>

				<section id="typography">
					<h2>Typography</h2>

					<h3>Font</h3>
					<dl>
						<dt>Light</dt>
						<dd>AaBbCcDdEeGgNn 1234567890</dd>
						<dt>Regular</dt>
						<dd>AaBbCcDdEeGgNn 1234567890</dd>
						<dt>Medium</dt>
						<dd>AaBbCcDdEeGgNn 1234567890</dd>
						<dt>Semi bold</dt>
						<dd>AaBbCcDdEeGgNn 1234567890</dd>
						<dt>Bold</dt>
						<dd>AaBbCcDdEeGgNn 1234567890</dd>
					</dl>

					<h3>Heading levels</h3>
					<h1>H1, nesciunt atque voluptatum velit fugiat corrupti deleniti</h1>
					<p>72px</p>
					<h2>H2</h2>
					<p>72px</p>
					<h3>H3</h3>
					<p>72px</p>
					<h4>H4</h4>
					<p>72px</p>
					<h5>H5</h5>
					<p>72px</p>
					<h6>H6</h6>
					<p>72px</p>

					<small>Small</small>

					<p>
						Lorem ipsum dolor sit amet consectetur adipisicing elit. Mollitia facilis modi vero fuga praesentium!
						Nesciunt atque maiores, laboriosam neque, eveniet voluptatum velit fugiat corrupti deleniti error nobis
						cupiditate nemo temporibus?
					</p>
				</section>

				<section id="spacing">
					<h2>Spacing</h2>
					<ul role="list">
						{
							// spacingNames.map((item) => (
							// 	<li>
							// 		<div
							// 			class={`circle`}
							// 			style={`inline-size: var(--space-${item})`}
							// 		/>
							// 		<span>
							// 			<h3>{item}</h3>
							// 			<code>--space-{item}</code>
							// 		</span>
							// 	</li>
							// ))
						}
					</ul>
				</section>
			</div>
		</div>
	</div>
</Layout>

<style>
	.circle {
		block-size: var(--space-md);
		background-color: var(--color-accent-fill-quiet);
		border: 1px solid var(--color-accent-border-quiet);
	}
</style>
