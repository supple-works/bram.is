---
import { getFullPageUrl } from "src/utilities/api/helpers/getParentPages";
import Layout from "../../../layouts/Layout.astro";
import { getStaticPathsFromData } from "src/utilities/api/helpers/getStaticPathsFromData";
import { getDataPageBlog, type PageBlogProps } from "src/utilities/api/pageBlog";
import { parseLink } from "src/utilities/link";
import { getLocaleFromURL } from "src/utilities/locale";
import { formatDateToISO, formatLongDate } from "src/utilities/date";

export async function getStaticPaths() {
	const data = await getDataPageBlog();
	return getStaticPathsFromData({ data, fragment: "blog" });
}

interface Props {
	pageData: PageBlogProps;
}

const { pageData } = Astro.props;

const locale = getLocaleFromURL(Astro.url.pathname);
---

<Layout metaData={pageData.metaData} type={pageData.type} alternativeTranslations={pageData.alternativeTranslations}>
	<section class="region">
		<div class="retain | flow">
			<h1>{pageData.title}</h1>

			<ol class="flow"role="list">
				{pageData.posts?.map((post) => (
					<li>
						<article>
							<h2 style={{"view-transition-name": `${post.slug}-title`}}><a href={parseLink(getFullPageUrl(post), locale)}>{post.title}</a></h2>
							<time style={{"view-transition-name": `${post.slug}-date`}} datetime={formatDateToISO(new Date(post.publishDate))} itemprop="datePublished">{formatLongDate(new Date(post.publishDate), locale.locale)}</time>
						</article>
					</li>
				))}
			</ol>
		</div>
	</section>
</Layout>
